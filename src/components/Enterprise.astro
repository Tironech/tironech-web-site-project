---
import content from '../data/content.json';
import '../styles/components/enterprise.css';
const { enterpriseServices } = content;
---
<section class="enterprise" id="enterprise" aria-labelledby="enterprise-title">
  <div class="enterprise-bg" aria-hidden="true">
    <img src="/assets/img/enterprise-section.jpg" alt="" loading="lazy" decoding="async" />
    <div class="enterprise-tint"></div>
  </div>
  <div class="container">
    <p class="section-eyebrow text-center reveal">SOLUCIONES ENTERPRISE · HIGH-TICKET</p>
    <h2 class="section-title text-center reveal" id="enterprise-title">
      Para empresas que requieren<br />
      <em>liderazgo técnico senior</em>.
    </h2>
    <p class="section-sub text-center reveal">
      Servicios de alto impacto para startups en USA que necesitan un CTO
      y para industrias que quieren llevar la IA al piso de producción.
    </p>

    <div class="enterprise-grid">
      {enterpriseServices.map((s) => (
        <article
          class:list={['enterprise-card reveal', { ai: s.featured }]}
          id={s.id}
          aria-labelledby={`${s.id}-title`}
        >
          <div class:list={['ent-tag', { amber: s.featured }]}>{s.tag}</div>
          <div class="ent-header">
            <div class:list={['ent-icon', { amber: s.featured }]} aria-hidden="true">{s.icon}</div>
            <div>
              <h3 class="ent-title" id={`${s.id}-title`}
                set:html={s.title.replace(' ', '<br />')}
              />
              <p class="ent-target">{s.target}</p>
            </div>
          </div>
          <p class="ent-value">{s.value}</p>
          <p class="ent-desc">{s.desc}</p>
          <ul class="ent-bullets" aria-label="Incluye">
            {s.features.map((f) => <li>{f}</li>)}
          </ul>
          <div class="ent-price">
            <div class="ent-price-val">{s.priceVal}</div>
            <div class="ent-price-model">{s.priceModel}</div>
          </div>
          <a href="#contact" class:list={['btn btn-full', s.ctaVariant]}>
            {s.ctaLabel} <span class="btn-arrow" aria-hidden="true">→</span>
          </a>
        </article>
      ))}
    </div>
  </div>
</section>
