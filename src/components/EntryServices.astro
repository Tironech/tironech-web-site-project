---
import content from '../data/content.json';
import '../styles/components/entry-services.css';
const { entryServices } = content;
---
<section class="entry-services" id="entry" aria-labelledby="entry-title">
  <div class="entry-accent" aria-hidden="true"></div>
  <div class="container">
    <p class="section-eyebrow text-center reveal">SOLUCIONES DE ENTRADA</p>
    <h2 class="section-title text-center reveal" id="entry-title">
      Empiece a ver resultados<br />
      <em>en las primeras dos semanas</em>.
    </h2>
    <p class="section-sub text-center reveal">
      Tres servicios diseñados para generar valor rápido con baja fricción
      de compra y resultados medibles desde el primer mes.
    </p>

    <div class="entry-grid">
      {entryServices.map((s) => (
        <article
          class:list={['entry-card reveal', { featured: s.featured }]}
          id={s.id}
          aria-labelledby={`${s.id}-title`}
        >
          <div class:list={['card-tag', { amber: s.featured }]}>{s.tag}</div>
          <div class:list={['card-icon', { amber: s.featured }]} aria-hidden="true">{s.icon}</div>
          <h3 class="card-title" id={`${s.id}-title`}
            set:html={s.title.replace('&', '&amp;')}
          />
          <p class="card-target">Para: <strong>{s.target}</strong></p>
          <p class="card-pain">{s.pain}</p>
          <p class="card-desc">{s.desc}</p>
          <ul class="card-features" aria-label="Características">
            {s.features.map((f) => <li>{f}</li>)}
          </ul>
          <div class="card-price">
            <span class="price-from">{s.priceFrom}</span>
            <span class="price-val">{s.priceVal}</span>
            <span class="price-model">{s.priceModel}</span>
          </div>
          <a href="#contact" class:list={['btn btn-card', s.ctaVariant]}>{s.ctaLabel} <span class="btn-arrow" aria-hidden="true">→</span></a>
        </article>
      ))}
    </div>
  </div>
</section>
