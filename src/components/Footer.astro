---
import content from '../data/content.json';
import '../styles/components/footer.css';
const { footerSolutions, footerCompany } = content;
const year = new Date().getFullYear();
---
<footer class="site-footer" role="contentinfo">
  <div class="container">
    <div class="footer-top">
      <div class="footer-brand">
        <p class="footer-logo">TIRONECH</p>
        <p class="footer-tagline">Ingeniería de alto valor. Resultados verificables.</p>
        <p class="footer-markets">USA · Latam Corporativo · SaaS B2B · Fintech</p>
      </div>
      <nav class="footer-nav" aria-label="Navegación del pie de página">
        <div class="footer-col">
          <p class="footer-col-title">Soluciones</p>
          <ul role="list">
            {footerSolutions.map((link) => (
              <li><a href={link.href}>{link.label}</a></li>
            ))}
          </ul>
        </div>
        <div class="footer-col">
          <p class="footer-col-title">Empresa</p>
          <ul role="list">
            {footerCompany.map((link) => (
              <li><a href={link.href}>{link.label}</a></li>
            ))}
          </ul>
        </div>
      </nav>
    </div>
    <div class="footer-bottom">
      <p>&copy; {year} TIRONECH. Todos los derechos reservados.</p>
      <p class="footer-motto">Juntos construimos algo diferente.</p>
    </div>
  </div>
</footer>
