---
import { ui } from '../i18n/ui';
import type { Lang } from '../i18n/ui';
import { getContent } from '../i18n/content';
import '../styles/components/footer.css';

const lang = (Astro.currentLocale ?? 'en') as Lang;
const t = ui[lang].footer;
const { footerSolutions, footerCompany } = getContent(lang);
const year = new Date().getFullYear();
---
<footer class="site-footer" role="contentinfo" data-testid="site-footer">
  <div class="container">
    <div class="footer-top">
      <div class="footer-brand">
        <p class="footer-logo">TIRONECH</p>
        <p class="footer-tagline">{t.tagline}</p>
        <p class="footer-markets">{t.markets}</p>

        <div class="footer-social" aria-label="Social media">
          <!-- TODO: reemplazar # con la URL real cuando se creen las cuentas -->
          <a href="#" class="social-link" aria-label="Tironech en LinkedIn" rel="noopener noreferrer" target="_blank">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
          <a href="#" class="social-link" aria-label="Tironech en Instagram" rel="noopener noreferrer" target="_blank">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/>
            </svg>
          </a>
          <a href="#" class="social-link" aria-label="Tironech en X (Twitter)" rel="noopener noreferrer" target="_blank">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.259 5.63L18.243 2.25zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
        </div>
      </div>
      <nav class="footer-nav" aria-label={t.navAriaLabel}>
        <div class="footer-col">
          <p class="footer-col-title">{t.solutionsTitle}</p>
          <ul role="list">
            {footerSolutions.map((link) => (
              <li><a href={link.href}>{link.label}</a></li>
            ))}
          </ul>
        </div>
        <div class="footer-col">
          <p class="footer-col-title">{t.companyTitle}</p>
          <ul role="list">
            {footerCompany.map((link) => (
              <li><a href={link.href}>{link.label}</a></li>
            ))}
          </ul>
        </div>
      </nav>
    </div>
    <div class="footer-bottom">
      <p>
        &copy; {year} TIRONECH. {t.copyright}
        <a href={lang === 'es' ? '/es/privacy' : '/privacy'} class="footer-legal" data-testid="footer-privacy">
          {lang === 'es' ? 'Política de Privacidad' : 'Privacy Policy'}
        </a>
      </p>
      <p class="footer-motto">{t.motto}</p>
    </div>
  </div>
</footer>
