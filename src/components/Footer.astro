---
import { ui } from '../i18n/ui';
import type { Lang } from '../i18n/ui';
import { getContent } from '../i18n/content';
import '../styles/components/footer.css';

const lang = (Astro.currentLocale ?? 'en') as Lang;
const t = ui[lang].footer;
const { footerSolutions, footerCompany } = getContent(lang);
const year = new Date().getFullYear();
---
<footer class="site-footer" role="contentinfo">
  <div class="container">
    <div class="footer-top">
      <div class="footer-brand">
        <p class="footer-logo">TIRONECH</p>
        <p class="footer-tagline">{t.tagline}</p>
        <p class="footer-markets">{t.markets}</p>
      </div>
      <nav class="footer-nav" aria-label={t.navAriaLabel}>
        <div class="footer-col">
          <p class="footer-col-title">{t.solutionsTitle}</p>
          <ul role="list">
            {footerSolutions.map((link) => (
              <li><a href={link.href}>{link.label}</a></li>
            ))}
          </ul>
        </div>
        <div class="footer-col">
          <p class="footer-col-title">{t.companyTitle}</p>
          <ul role="list">
            {footerCompany.map((link) => (
              <li><a href={link.href}>{link.label}</a></li>
            ))}
          </ul>
        </div>
      </nav>
    </div>
    <div class="footer-bottom">
      <p>&copy; {year} TIRONECH. {t.copyright}</p>
      <p class="footer-motto">{t.motto}</p>
    </div>
  </div>
</footer>
