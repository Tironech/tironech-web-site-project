---
import '../styles/components/hero.css';
---
<section class="hero" id="home" aria-labelledby="hero-title">
  <div class="hero-gradient" data-mouse-gradient aria-hidden="true"></div>
  <div class="hero-noise" aria-hidden="true"></div>
  <div class="hero-img-wrap" aria-hidden="true">
    <img
      src="/assets/img/hero.jpg"
      alt="Espacio de trabajo de ingeniería con interfaces de código e inteligencia artificial"
      class="hero-bg-img"
      fetchpriority="high"
      loading="eager"
      decoding="async"
    />
    <div class="hero-img-tint"></div>
  </div>

  <div class="container hero-inner">
    <p class="hero-kicker">
      <span class="kicker-dot" aria-hidden="true"></span>
      <span>BOUTIQUE DE INGENIERÍA · B2B · USA &amp; LATAM</span>
    </p>

    <h1 class="hero-title" id="hero-title">
      Bugs en producción.<br />
      Sin equipo senior.<br />
      Tecnología que no escala.<br />
      <em>Nosotros resolvemos los tres.</em>
    </h1>

    <p class="hero-sub">
      QA avanzado con IA, arquitectura sin deuda técnica y equipos de
      desarrollo llave en mano. Para startups y empresas que no pueden
      darse el lujo de fallar en producción.
    </p>

    <div class="hero-actions">
      <a href="#contact" class="btn btn-cta">
        Agendar sesión de descubrimiento <span class="btn-arrow" aria-hidden="true">→</span>
      </a>
      <a href="#entry" class="btn btn-ghost">
        Ver soluciones <span class="btn-arrow" aria-hidden="true">↓</span>
      </a>
    </div>

    <div class="hero-markets" aria-label="Mercados que atendemos">
      <span class="market-label">Atendemos:</span>
      <span>SaaS B2B</span>
      <span class="sep" aria-hidden="true">·</span>
      <span>Fintech</span>
      <span class="sep" aria-hidden="true">·</span>
      <span>Startups USA</span>
      <span class="sep" aria-hidden="true">·</span>
      <span>Latam Corporativo</span>
    </div>
  </div>

  <div class="hero-scroll-cue" aria-hidden="true">
    <div class="scroll-line"></div>
    <span class="scroll-label">scroll</span>
  </div>
</section>
