---
import content from '../data/content.json';
import '../styles/components/leadership.css';
const { teamMembers } = content;
---
<section class="leadership" id="leadership" aria-labelledby="leadership-title">
  <div class="container">
    <p class="section-eyebrow text-center reveal">LIDERAZGO TÉCNICO</p>
    <h2 class="section-title text-center reveal" id="leadership-title">
      Respaldados por cofundadores y<br />
      <em>talento especializado de élite</em>.
    </h2>
    <p class="leadership-intro text-center reveal">
      Nuestro equipo directivo está conformado por los cofundadores de Tironech,
      liderazgo especializado en diseño y desarrollo frontend, y expertos técnicos
      con experiencia comprobada en QA avanzado, arquitectura de IA y DevOps.
      Los perfiles individuales se publicarán próximamente.
    </p>

    <div class="team-grid">
      {teamMembers.map((m) => (
        <div class="team-card reveal" aria-label="Perfil próximamente">
          <div class:list={['team-avatar', { amber: m.avatarVariant === 'team-avatar--amber' }]} aria-hidden="true">
            <span>{m.initials}</span>
          </div>
          <div>
            <p class="team-role">{m.role}</p>
            <p class="team-area">{m.area}</p>
            <p class="team-focus">{m.focus}</p>
          </div>
        </div>
      ))}
    </div>

    <p class="coming-soon-note reveal">
      <span class="coming-badge">Próximamente</span>
      Perfiles completos con biografías, trayectoria y casos de impacto de cada miembro del equipo.
    </p>
  </div>
</section>
