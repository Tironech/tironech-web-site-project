---
import '../styles/components/nav.css';
---
<header class="site-nav" role="banner">
  <nav class="nav-inner container" aria-label="Navegación principal">

    <a href="#home" class="nav-logo" aria-label="Tironech — Inicio">
      <img src="/assets/logo/mark.png" alt="" width="70" height="75" loading="eager" decoding="sync" />
      <span class="logo-full">TIRONECH</span>
    </a>

    <ul class="nav-links" role="list">
      <li><a href="#about"      class="nav-link">Empresa</a></li>
      <li><a href="#entry"      class="nav-link">Soluciones</a></li>
      <li><a href="#enterprise" class="nav-link">Enterprise</a></li>
      <li><a href="#why-us"     class="nav-link">Por qué nosotros</a></li>
      <li><a href="#leadership" class="nav-link">Equipo</a></li>
    </ul>

    <div class="nav-actions">
      <a href="#contact" class="btn btn-cta btn-sm">Agendar sesión →</a>
      <button
        class="nav-burger"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label="Abrir menú"
      >
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>
</header>

<div class="mobile-menu" id="mobile-menu" aria-hidden="true">
  <ul role="list">
    <li><a href="#about"      class="mobile-link">Empresa</a></li>
    <li><a href="#entry"      class="mobile-link">Soluciones de entrada</a></li>
    <li><a href="#enterprise" class="mobile-link">Enterprise</a></li>
    <li><a href="#why-us"     class="mobile-link">Por qué nosotros</a></li>
    <li><a href="#leadership" class="mobile-link">Equipo</a></li>
    <li><a href="#contact"    class="mobile-link mobile-cta">Agendar sesión →</a></li>
  </ul>
</div>
