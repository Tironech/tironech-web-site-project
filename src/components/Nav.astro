---
import { Image } from 'astro:assets';
import { ui } from '../i18n/ui';
import type { Lang } from '../i18n/ui';
import '../styles/components/nav.css';

const lang = (Astro.currentLocale ?? 'en') as Lang;
const t = ui[lang].nav;
const ls = ui[lang].langSwitch;
---
<header class="site-nav" role="banner">
  <nav class="nav-inner container" aria-label={t.ariaLabel}>

    <a href="#home" class="nav-logo" aria-label="Tironech — Inicio">
      <Image src="/assets/logo/logo.webp" alt="Tironech logo" width={70} height={75} loading="eager" fetchpriority="high" />
      <span class="logo-full">TIRONECH</span>
    </a>

    <ul class="nav-links" role="list">
      <li><a href="#about"      class="nav-link">{t.company}</a></li>
      <li><a href="#entry"      class="nav-link">{t.solutions}</a></li>
      <li><a href="#enterprise" class="nav-link">{t.enterprise}</a></li>
      <li><a href="#why-us"     class="nav-link">{t.whyUs}</a></li>
      <li><a href="#leadership" class="nav-link">{t.team}</a></li>
    </ul>

    <div class="nav-actions">
      <a href={ls.href} class="lang-btn" aria-label={ls.ariaLabel}>{ls.label}</a>
      <a href="#contact" class="btn btn-cta btn-sm">{t.cta}</a>
      <button
        class="nav-burger"
        aria-expanded="false"
        aria-controls="mobile-menu"
        aria-label={t.burgerLabel}
      >
        <span></span><span></span><span></span>
      </button>
    </div>
  </nav>
</header>

<div class="mobile-menu" id="mobile-menu" aria-hidden="true">
  <ul role="list">
    <li><a href="#about"      class="mobile-link">{t.company}</a></li>
    <li><a href="#entry"      class="mobile-link">{t.mobileSolutions}</a></li>
    <li><a href="#enterprise" class="mobile-link">{t.enterprise}</a></li>
    <li><a href="#why-us"     class="mobile-link">{t.whyUs}</a></li>
    <li><a href="#leadership" class="mobile-link">{t.team}</a></li>
    <li><a href="#contact"    class="mobile-link mobile-cta">{t.cta}</a></li>
  </ul>
</div>
