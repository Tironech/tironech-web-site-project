---
import content from '../data/content.json';
import '../styles/components/trust-strip.css';
const { markets } = content;
---
<div class="trust-strip" aria-label="Mercados que atendemos">
  {markets.map((m, i) => (
    <>
      <span>{m}</span>
      {i < markets.length - 1 && <span class="trust-sep" aria-hidden="true">·</span>}
    </>
  ))}
</div>
