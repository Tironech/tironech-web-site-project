---
import content from '../data/content.json';
import '../styles/components/why-us.css';
const { whyItems } = content;
---
<section class="why-us" id="why-us" aria-labelledby="why-title">
  <div class="container">
    <p class="section-eyebrow text-center reveal">POR QUÉ ELEGIR TIRONECH</p>
    <h2 class="section-title text-center reveal" id="why-title">
      Lo que diferencia a una boutique<br />
      de ingeniería de <em>una agencia genérica</em>.
    </h2>

    <div class="why-grid">
      {whyItems.map((item) => (
        <div class="why-item reveal">
          <div class:list={['why-icon', { amber: item.iconVariant === 'why-icon--amber' }]} aria-hidden="true">
            {item.icon}
          </div>
          <div class="why-content">
            <h3>{item.title}</h3>
            <p>{item.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
