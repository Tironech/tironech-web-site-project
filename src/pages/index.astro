---
import BaseLayout from '../layouts/BaseLayout.astro';
import Cursor from '../components/Cursor.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import TrustStrip from '../components/TrustStrip.astro';
import About from '../components/About.astro';
import EntryServices from '../components/EntryServices.astro';
import Enterprise from '../components/Enterprise.astro';
import WhyUs from '../components/WhyUs.astro';
import Leadership from '../components/Leadership.astro';
import Contact from '../components/Contact.astro';
import Footer from '../components/Footer.astro';

const title = 'Tironech — Ingeniería de alto valor. QA, AI & Dev.';
const description = 'Boutique de ingeniería para startups y empresas. QA avanzado con IA, Fractional CTO, Edge AI Vision y desarrollo a medida para USA y Latam. Resultados desde la primera semana.';
---
<BaseLayout title={title} description={description}>
  <Cursor />
  <Nav />
  <main id="main-content">
    <Hero />
    <TrustStrip />
    <About />
    <EntryServices />
    <Enterprise />
    <WhyUs />
    <Leadership />
    <Contact />
  </main>
  <Footer />
</BaseLayout>
